#!/bin/sh
# ghosted — open a folder in Ghosted from the terminal (like `code .`)
# usage: ghosted [dir]   (defaults to the current directory)

TARGET="${1:-.}"

case "$TARGET" in
  -h|--help)
    echo "usage: ghosted [dir]           open a directory as a Ghosted workspace"
    echo "       ghosted open <file>     open a file in the running Ghosted editor"
    echo "                               (inside Ghosted's terminal, via \$GHOSTED_SOCKET)"
    echo "Set GHOSTED_BIN to point at a custom app binary."
    exit 0
    ;;
  open)
    # RPC into the running instance — available inside Ghosted's terminal
    FILE="$2"
    [ -n "$FILE" ] || { echo "usage: ghosted open <file>" >&2; exit 1; }
    [ -n "$GHOSTED_SOCKET" ] || { echo "ghosted: GHOSTED_SOCKET not set — run inside Ghosted's terminal" >&2; exit 1; }
    DIR="$(cd "$(dirname "$FILE")" 2>/dev/null && pwd)" || { echo "ghosted: no such file: $FILE" >&2; exit 1; }
    ABSFILE="$DIR/$(basename "$FILE")"
    python3 - "$GHOSTED_SOCKET" "$ABSFILE" <<'PY'
import json, socket, sys
sock, target = sys.argv[1], sys.argv[2]
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.connect(sock)
s.sendall((json.dumps({"id": 1, "method": "openFile", "params": {"path": target}}) + "\n").encode())
res = json.loads(s.makefile().readline())
if not res.get("ok"):
    print(f"ghosted: {res.get('error')}", file=sys.stderr)
    sys.exit(1)
PY
    exit $?
    ;;
esac

ABS="$(cd "$TARGET" 2>/dev/null && pwd)" || {
  echo "ghosted: no such directory: $TARGET" >&2
  exit 1
}

BIN="$GHOSTED_BIN"
if [ -z "$BIN" ]; then
  for candidate in \
    "/Applications/Ghosted.app/Contents/MacOS/Ghosted" \
    "$HOME/Applications/Ghosted.app/Contents/MacOS/Ghosted" \
    "/opt/Ghosted/ghosted" \
    "$HOME/.local/bin/Ghosted.AppImage"; do
    if [ -x "$candidate" ]; then
      BIN="$candidate"
      break
    fi
  done
fi

if [ -z "$BIN" ]; then
  echo "ghosted: Ghosted app binary not found — set GHOSTED_BIN=/path/to/binary" >&2
  exit 1
fi

# Detach so the shell isn't held open; the single-instance lock hands the
# path to a running Ghosted if one exists.
nohup "$BIN" "$ABS" >/dev/null 2>&1 &
