{
  "name": "ghosted",
  "version": "0.1.0",
  "description": "Ghosted — the dev workspace that never sleeps.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.electron.json && vite build",
    "preview": "electron .",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "keywords": [
    "ghosted",
    "ide",
    "agent",
    "bruceos"
  ],
  "author": "Megasupersoft Ltd",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^7.0.0",
    "@dnd-kit/utilities": "^3.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@octokit/graphql": "^8.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xyflow/react": "^12.0.0",
    "chokidar": "^3.5.0",
    "force-graph": "^1.51.2",
    "node-pty": "^1.0.0",
    "react": "^18.0.0",
    "react-arborist": "^3.4.0",
    "react-dom": "^18.0.0",
    "react-markdown": "^9.0.0",
    "react-resizable-panels": "^2.0.0",
    "xterm": "^5.3.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.megasupersoft.ghosted",
    "productName": "Ghosted",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
