{
  "name": "ghosted",
  "version": "0.1.2",
  "description": "Ghosted \u2014 the dev workspace that never sleeps.",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "bash scripts/setup-mac.sh && node scripts/rebuild-pty.js",
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "preview": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "lint": "biome check src electron vite.config.ts",
    "lint:fix": "biome check --write src electron vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "dist": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --linux --mac --win"
  },
  "keywords": [
    "ghosted",
    "ide",
    "agent",
    "bruceos"
  ],
  "author": "Megasupersoft Ltd",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mariozechner/pi-coding-agent": "^0.60.0",
    "@monaco-editor/react": "^4.7.0",
    "@sinclair/typebox": "^0.34.52",
    "@tailwindcss/vite": "^4.3.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.2",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "force-graph": "^1.51.4",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.25.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.12.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.megasupersoft.ghosted",
    "productName": "Ghosted",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/node-pty/**/*",
      "!node_modules/node-pty/build/Release/.deps",
      "!node_modules/node-pty/src/**",
      "!node_modules/node-pty/deps/**",
      "build/icon-1024.png"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "linux": {
      "target": "AppImage",
      "icon": "build/icons",
      "category": "Development",
      "desktop": {
        "entry": {
          "Name": "Ghosted",
          "Comment": "The dev workspace that never sleeps",
          "Terminal": "false",
          "Type": "Application",
          "Categories": "Development;IDE;TextEditor;"
        }
      }
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon-1024.png"
    },
    "win": {
      "target": "nsis"
    },
    "afterPack": "./scripts/afterPack.js",
    "afterSign": "./scripts/afterSign.js",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "ghosted"
        ]
      }
    ]
  }
}
